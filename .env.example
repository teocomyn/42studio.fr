# Envoi du formulaire de contact via Resend — https://resend.com
# Sans RESEND_API_KEY, le formulaire invite à écrire directement par email (fallback mailto).
RESEND_API_KEY=

# Adresse qui reçoit les briefs (défaut : hello@42studio.fr).
CONTACT_TO=hello@42studio.fr

# Expéditeur : doit être une adresse d'un domaine vérifié dans Resend.
# Défaut : domaine de test Resend (onboarding@resend.dev).
CONTACT_FROM=42studio <onboarding@resend.dev>
