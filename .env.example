# Formulaire contact (Resend) — requis en production
# Crée la clé sur https://resend.com/api-keys puis ajoute-la aussi dans Vercel
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx

# Destinataire des briefs
CONTACT_TO=hello@42studio.fr

# Expéditeur — domaine 42studio.fr doit être vérifié dans Resend
CONTACT_FROM=42studio <hello@42studio.fr>

# Prise de RDV (Cal.com / Calendly) — affiche le bouton sur /contact
NEXT_PUBLIC_BOOKING_URL=

# Google Analytics 4
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-ZTMCPNWGL5
